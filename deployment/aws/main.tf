terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

# Variables
variable "region" {
  description = "AWS region"
  type        = string
  default     = "ap-northeast-2"
}

variable "team_name" {
  description = "Team name (used for resource naming)"
  type        = string
  default     = "runeconsole"
}

variable "tls_mode" {
  description = "TLS mode: self-signed or none"
  type        = string
  default     = "self-signed"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "t3.medium" # 2 vCPU, 4GB RAM
}

variable "runeconsole_version" {
  description = "Pinned runeconsole release tag — drives the install.sh URL and binary version on the VM."
  type        = string
}

variable "public_key" {
  description = "SSH public key content for EC2 access"
  type        = string
  default     = ""
}

# Data sources
data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"] # Canonical

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd-gp3/ubuntu-noble-24.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# VPC
resource "aws_vpc" "console_vpc" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name    = "rune-console-${var.team_name}"
    Project = "Rune"
    Team    = var.team_name
  }
}

# Internet Gateway
resource "aws_internet_gateway" "console_igw" {
  vpc_id = aws_vpc.console_vpc.id

  tags = {
    Name    = "rune-console-igw-${var.team_name}"
    Project = "Rune"
  }
}

# Public Subnet
resource "aws_subnet" "console_subnet" {
  vpc_id                  = aws_vpc.console_vpc.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = data.aws_availability_zones.available.names[0]
  map_public_ip_on_launch = true

  tags = {
    Name    = "rune-console-subnet-${var.team_name}"
    Project = "Rune"
  }
}

data "aws_availability_zones" "available" {
  state = "available"
}

# Route Table
resource "aws_route_table" "console_rt" {
  vpc_id = aws_vpc.console_vpc.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.console_igw.id
  }

  tags = {
    Name    = "rune-console-rt-${var.team_name}"
    Project = "Rune"
  }
}

resource "aws_route_table_association" "console_rta" {
  subnet_id      = aws_subnet.console_subnet.id
  route_table_id = aws_route_table.console_rt.id
}

# Security Group
resource "aws_security_group" "console_sg" {
  name        = "rune-console-sg-${var.team_name}"
  description = "Security group for Rune-Console"
  vpc_id      = aws_vpc.console_vpc.id

  # gRPC
  ingress {
    from_port   = 50051
    to_port     = 50051
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "gRPC (public)"
  }

  # SSH
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH (restrict to your IP in production)"
  }

  # Outbound
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow all outbound"
  }

  tags = {
    Name    = "rune-console-sg-${var.team_name}"
    Project = "Rune"
  }
}

# SSH Key Pair (auto-generated by install.sh)
resource "aws_key_pair" "console_key" {
  count      = var.public_key != "" ? 1 : 0
  key_name   = "rune-console-${var.team_name}"
  public_key = var.public_key

  tags = {
    Name    = "rune-console-${var.team_name}"
    Project = "Rune"
  }
}

# EC2 Instance
resource "aws_instance" "console" {
  ami                    = data.aws_ami.ubuntu.id
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.console_subnet.id
  vpc_security_group_ids = [aws_security_group.console_sg.id]
  key_name               = var.public_key != "" ? aws_key_pair.console_key[0].key_name : null

  user_data = templatefile("${path.module}/cloud-init.yaml", {
    runeconsole_version = var.runeconsole_version
  })

  root_block_device {
    volume_size           = 20
    volume_type           = "gp3"
    encrypted             = true
    delete_on_termination = true
  }

  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required" # IMDSv2
    http_put_response_hop_limit = 1
  }

  tags = {
    Name    = "rune-console-${var.team_name}"
    Project = "Rune"
    Team    = var.team_name
  }
}

# Elastic IP (optional, for stable endpoint)
resource "aws_eip" "console_eip" {
  instance = aws_instance.console.id
  domain   = "vpc"

  tags = {
    Name    = "rune-console-eip-${var.team_name}"
    Project = "Rune"
  }
}

# Outputs
output "console_url" {
  description = "Rune-Console gRPC endpoint"
  value       = "${aws_eip.console_eip.public_ip}:50051"
}

output "console_public_ip" {
  description = "Public IP address"
  value       = aws_eip.console_eip.public_ip
}

output "console_private_ip" {
  description = "Private IP address"
  value       = aws_instance.console.private_ip
}

output "ssh_command" {
  description = "SSH command to connect to Console instance"
  value       = var.public_key != "" ? "ssh ubuntu@${aws_eip.console_eip.public_ip}" : "SSH key not configured"
}

output "instance_id" {
  description = "EC2 instance ID"
  value       = aws_instance.console.id
}
